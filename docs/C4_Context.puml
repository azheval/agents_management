@startuml C4_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Agent Management System Context Diagram

Person(admin, "System Administrator", "Configures the platform, users, access policies, and saved EXEC_COMMAND policies and bindings.")
Person(operator, "Operator", "Authenticated user with permissions limited by roles, agent access matrix, and EXEC_COMMAND policy permissions.")
System(agent_system, "Agent Management System", "System for executing tasks on remote machines with authentication, role-based access control, and saved EXEC_COMMAND policies with per-agent bindings.")

System_Ext(telegram, "Telegram API", "Messaging platform.")

Rel(admin, agent_system, "Manages agents, users, roles and tasks", "Uses web interface")
Rel(operator, agent_system, "Works with agents and tasks according to assigned permissions", "Uses web interface")
Rel(agent_system, telegram, "Sends task status notifications")

@enduml
